# Supabase project credentials.
# The publishable (anon) key is safe for client exposure, so it's prefixed
# with NEXT_PUBLIC_ so Next.js inlines it for both server and client components.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key — server-only, never expose to the client or commit.
SUPABASE_SECRET_KEY=

# Admin dashboard login password (hashed to cookie token server-side).
ADMIN_SECRET=

# Optional — AI Operation Assistant (OpenAI). Falls back to rule engine if unset.
# OPS_AI_API_KEY=
# OPS_AI_MODEL=gpt-4o-mini
