{
  "name": "game-platform",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "games/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@game-platform/web",
    "build": "npm run build --workspace=@game-platform/web",
    "lint": "npm run lint --workspace=@game-platform/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "factory:generate": "node tools/content-factory/cli.mjs generate",
    "factory:scaffold": "node tools/content-factory/cli.mjs scaffold",
    "factory:batch": "node tools/content-factory/cli.mjs batch",
    "factory:sync-rc1": "node tools/content-factory/scripts/extract-game-metadata.mjs && node tools/content-factory/scripts/sync-rc1-packages.mjs",
    "analytics:validate": "node tools/analytics/generate-validation-report.mjs"
  }
}
